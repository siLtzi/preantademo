---
interface Props {
  data?: any;
  settings?: any;
}
const { data, settings } = Astro.props;

const tag = data?.ctaTag || 'Ota yhteyttä';
const title = data?.ctaTitle || 'Luodaan yhdessä jotain *näyttävää*';
const description = data?.ctaDescription || 'Kerro meille projektistasi ja tehdään brändistäsi näkyvä. Tarjous on aina maksuton.';
const emailButtonText = data?.ctaEmailButtonText || 'Lähetä viesti';
const email = settings?.email || 'myynti@preanta.fi';
const phone = settings?.phone || '040 962 8962';
const address = data?.ctaAddress || settings?.address || 'Voudintie 8, 90400 Oulu';
const hours = data?.ctaHours || settings?.businessHours || 'Ma–To 8–16 · Pe 8–15';

function renderTitle(text: string) {
  return text.replace(/\*(.+?)\*/g, '<em>$1</em>');
}
---

<section class="cta-section" id="yhteystiedot">
  <span class="section-tag reveal" style="justify-content:center">{tag}</span>
  <h2 class="cta-title reveal" set:html={renderTitle(title)} />
  <p class="cta-desc reveal">{description}</p>
  <div class="cta-actions reveal">
    <a href={`mailto:${email}`} class="btn-primary">
      {emailButtonText}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
    <a href={`tel:${phone.replace(/\s/g, '')}`} class="btn-secondary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {phone}
    </a>
  </div>
  <div class="cta-contact-row reveal">
    <div class="cta-contact-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      {address}
    </div>
    <div class="cta-contact-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      {hours}
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 10rem 6rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(217,48,37,0.06), transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(217,48,37,0.04), transparent 50%);
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    position: relative;
  }
  .cta-title :global(em) { font-style: italic; color: var(--red); }
  .cta-desc {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--gray-600);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    position: relative;
  }
  .cta-actions {
    display: flex; gap: 1rem; justify-content: center;
    position: relative;
  }
  .cta-contact-row {
    display: flex; gap: 3rem; justify-content: center;
    margin-top: 3rem;
    position: relative;
  }
  .cta-contact-item {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--gray-600);
  }
  .cta-contact-item a {
    color: var(--black);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.25s;
  }
  .cta-contact-item a:hover { color: var(--red); }

  @media (max-width: 1024px) {
    .cta-section { padding: 6rem 3rem; }
  }
  @media (max-width: 640px) {
    .cta-section { padding: 5rem 1.5rem; }
    .cta-contact-row { flex-direction: column; gap: 1rem; }
  }
</style>
