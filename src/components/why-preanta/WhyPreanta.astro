---
interface Props {
  data?: any;
}
const { data } = Astro.props;

const tag = data?.whyTag || 'Miksi Preanta';
const title = data?.whyTitle || 'Laatua ja luotettavuutta vuodesta 2015';
const description = data?.whyDescription || 'Tarkka sisäinen laadunvalvonta pitää huolen, että tuotamme priimaa joka kerta. Palvelu on meillä etusijalla.';

const defaultCards = [
  { title: 'Laatu ensin', description: 'Tarkka laadunvalvonta jokaisessa vaiheessa. Priimaa kerrasta toiseen.' },
  { title: 'Nopea toimitus', description: 'Tehokas tuotanto ja selkeä aikataulu. Tiedät aina missä mennään.' },
  { title: 'Henkilökohtainen palvelu', description: 'Kuuntelemme ja suunnittelemme yhdessä. Sinun tarpeesi ohjaavat meitä.' },
  { title: 'Kaikki saman katon alta', description: 'Brodeeraus, paino, tarrat ja ompelupalvelu — ei tarvitse juosta ympäriinsä.' },
];

const whyCards = data?.whyCards?.length ? data.whyCards : defaultCards;

// SVG icons for each card position
const icons = [
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
];
---

<section class="why-section" id="miksi">
  <div class="why-grid reveal">
    <div class="why-left">
      <span class="section-tag" style="color: var(--red-light);">{tag}</span>
      <h2 class="section-title" style="color: white; margin-bottom: 1.5rem;">{title}</h2>
      <p class="section-desc" style="color: rgba(255,255,255,0.6);">{description}</p>
    </div>
    <div class="why-right">
      {whyCards.map((card: any, i: number) => (
        <div class={`why-card reveal reveal-delay-${i + 1}`}>
          <div class="why-card-icon">
            <Fragment set:html={icons[i] || icons[0]} />
          </div>
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-section {
    padding: 0 6rem 8rem;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 0;
    border-radius: 24px;
    overflow: hidden;
    min-height: 600px;
  }
  .why-left {
    background: var(--black);
    padding: 5rem;
    display: flex; flex-direction: column; justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .why-left::before {
    content: '';
    position: absolute; top: -50%; right: -30%;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(217,48,37,0.15), transparent 70%);
  }
  .why-right {
    background: var(--gray-100);
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .why-card {
    padding: 2rem;
    border-radius: 16px;
    background: white;
    border: 1px solid var(--gray-200);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }
  .why-card:hover {
    border-color: var(--red);
    box-shadow: 0 8px 40px rgba(217,48,37,0.08);
    transform: translateY(-4px);
  }
  .why-card-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--red), var(--red-light));
    display: flex; align-items: center; justify-content: center;
    color: white;
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .why-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .why-card p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--gray-600);
  }

  @media (max-width: 1024px) {
    .why-section { padding: 0 3rem 5rem; }
    .why-grid { grid-template-columns: 1fr; }
    .why-left { padding: 3rem; }
    .why-right { padding: 2rem; }
  }
  @media (max-width: 640px) {
    .why-section { padding: 0 1.5rem 4rem; }
    .why-right { grid-template-columns: 1fr; }
  }
</style>
